APP_NAME="نظام نقطة البيع"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://127.0.0.1:8000/

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_system
DB_USERNAME=root
DB_PASSWORD=

# FIX-1: تشفير الجلسات إجباري في الإنتاج
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="pos@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# FIX-2: كلمات مرور إلزامية — لا تترك هذه الحقول فارغة قبل الـ seed
# يجب تغييرها قبل النشر في الإنتاج
ADMIN_PASSWORD=
CASHIER_PASSWORD=
WAREHOUSE_PASSWORD=

# FIX-3: حد الخصم الأقصى (نسبة مئوية 0-100)
MAX_DISCOUNT_PERCENT=20

# إعدادات الأمان
ANOMALY_INVOICE_THRESHOLD=50000
ANOMALY_REQUESTS_PER_MINUTE=100
ANOMALY_FAILED_LOGINS=10

# FIX-8: Laravel Backup
BACKUP_DISK=local
BACKUP_NOTIFY_EMAIL=admin@example.com
BACKUP_ARCHIVE_PASSWORD=       # REQUIRED — set a strong password before enabling backups

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_MANAGER_PHONE=
WHATSAPP_LARGE_INVOICE_AMOUNT=5000
WHATSAPP_LANGUAGE=ar
WA_TEMPLATE_INVOICE=invoice_notification
WA_TEMPLATE_DEBT_REMINDER=debt_reminder
WA_TEMPLATE_DAILY_SUMMARY=daily_sales_summary
WA_TEMPLATE_LOW_STOCK=low_stock_alert
WA_TEMPLATE_LARGE_INVOICE=large_invoice_alert
WA_TEMPLATE_PROMOTION=vip_promotion

# ── Thermal Printing ──────────────────────────────────────────────────────────
THERMAL_PRINTING_ENABLED=true

# Printer hardware defaults
PRINTER_PAPER_WIDTH=80          # 58 or 80 (mm)
PRINTER_CHARACTER_SET=CP720     # CP437 | CP720 (Arabic) | UTF-8
PRINTER_COPIES=1
PRINTER_AUTO_CUT=true
PRINTER_AUTO_OPEN_DRAWER=false
PRINTER_PORT=9100               # ESC/POS default TCP port
PRINTER_TIMEOUT=5               # seconds — network connection timeout

# Print job queue
PRINT_MAX_ATTEMPTS=3            # retry limit before job is marked failed
PRINT_BATCH_SIZE=10             # jobs processed per scheduler tick
PRINT_STUCK_THRESHOLD=5         # minutes before a "processing" job is released

# Receipt options
RECEIPT_SHOW_QR=true            # print ETA QR code on receipts
RECEIPT_SHOW_BARCODE=false      # print barcode on receipts
RECEIPT_TEMPLATE=default        # receipt template name
RECEIPT_FOOTER=                 # optional footer text printed at bottom

# ETA QR code on receipts
ETA_QR_ENABLED=true

# ETA — منظومة الفاتورة الإلكترونية المصرية
ETA_ENABLED=false
ETA_BASE_URL=https://api.invoicing.eta.gov.eg
ETA_IDENTITY_URL=https://id.eta.gov.eg
ETA_CLIENT_ID=
ETA_CLIENT_SECRET=
ETA_TAX_NUMBER=
ETA_ISSUER_NAME=
ETA_GOVERNATE=Cairo
ETA_CITY=
ETA_STREET=
ETA_BUILDING=
ETA_ACTIVITY_CODE=
ETA_SIGNING_ENABLED=true
ETA_PKCS11_MODULE=
ETA_TOKEN_PIN=
ETA_CERT_ALIAS=

VITE_APP_NAME="${APP_NAME}"
