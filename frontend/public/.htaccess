<IfModule mod_headers.c>
    # index.html must always be revalidated — it references hashed asset
    # filenames from the *current* build. If it's cached stale by the
    # browser/CDN after a new deploy, it points at chunk files (e.g.
    # RegisterPage-xxxx.js) that no longer exist on disk, causing
    # "Failed to fetch dynamically imported module" errors.
    <FilesMatch "^index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

    # Hashed assets (filename changes whenever content changes) are safe
    # to cache for a long time.
    <FilesMatch "\.(js|css|woff2?|ttf|svg|png|jpg|jpeg|gif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
